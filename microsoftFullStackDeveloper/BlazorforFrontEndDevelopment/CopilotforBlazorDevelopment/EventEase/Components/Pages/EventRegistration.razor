@code {
    [Parameter]
    public int EventId { get; set; }

    private Event? selectedEvent;
    private bool isSubmitted = false;
    private bool isProcessing = false;
    private string? errorMessage;
    private List<string> validationErrors = new();
    
    private RegistrationFormData formData = new();

    private class RegistrationFormData
    {
        public string FirstName { get; set; } = string.Empty;
        public string LastName { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string Phone { get; set; } = string.Empty;
        public string Company { get; set; } = string.Empty;
        public bool AcceptTerms { get; set; }

        public bool IsValid()
        {
            return !string.IsNullOrWhiteSpace(FirstName) &&
                   !string.IsNullOrWhiteSpace(LastName) &&
                   !string.IsNullOrWhiteSpace(Email) &&
                   AcceptTerms;
        }
    }

    protected override void OnInitialized()
    {
        try
        {
            if (EventId <= 0)
            {
                errorMessage = "Invalid event ID provided.";
                return;
            }

            // Load event data
            var allEvents = new List<Event>
            {
                new Event 
                { 
                    Id = 1,
                    EventName = "Annual Tech Conference 2024",
                    Description = "Join industry leaders for keynote speeches and networking",
                    EventDate = DateTime.Now.AddDays(15),
                    Location = "San Francisco Convention Center",
                    Category = "Technology",
                    MaxAttendees = 500,
                    RegisteredAttendees = 342
                },
                new Event 
                { 
                    Id = 2,
                    EventName = "Business Networking Breakfast",
                    Description = "Start your morning with coffee and valuable business connections",
                    EventDate = DateTime.Now.AddDays(5),
                    Location = "Downtown Hilton",
                    Category = "Networking",
                    MaxAttendees = 50,
                    RegisteredAttendees = 45
                },
                new Event 
                { 
                    Id = 3,
                    EventName = "C# Workshop for Beginners",
                    Description = "Learn C# fundamentals with hands-on exercises",
                    EventDate = DateTime.Now.AddDays(22),
                    Location = "Tech Academy Building",
                    Category = "Workshop",
                    MaxAttendees = 100,
                    RegisteredAttendees = 67
                },
                new Event 
                { 
                    Id = 4,
                    EventName = "Corporate Award Ceremony",
                    Description = "Celebrate excellence and company achievements",
                    EventDate = DateTime.Now.AddDays(45),
                    Location = "Grand Ballroom Hotel",
                    Category = "Corporate",
                    MaxAttendees = 300,
                    RegisteredAttendees = 156
                },
                new Event 
                { 
                    Id = 5,
                    EventName = "Web Development Bootcamp",
                    Description = "Intensive 3-day program on modern web technologies",
                    EventDate = DateTime.Now.AddDays(30),
                    Location = "Innovation Hub",
                    Category = "Workshop",
                    MaxAttendees = 75,
                    RegisteredAttendees = 75
                }
            };

            selectedEvent = allEvents.FirstOrDefault(e => e.Id == EventId);
            
            if (selectedEvent == null)
            {
                errorMessage = $"Event with ID {EventId} not found.";
            }
            else if (!selectedEvent.IsValid())
            {
                errorMessage = "Event data is invalid. Please try again later.";
                selectedEvent = null;
            }
            else if (!selectedEvent.IsAvailable)
            {
                errorMessage = "This event is full and cannot accept new registrations.";
                selectedEvent = null;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading event: {ex.Message}";
        }
    }

    private void ValidateForm()
    {
        validationErrors.Clear();

        if (string.IsNullOrWhiteSpace(formData.FirstName))
            validationErrors.Add("First name is required.");

        if (string.IsNullOrWhiteSpace(formData.LastName))
            validationErrors.Add("Last name is required.");

        if (string.IsNullOrWhiteSpace(formData.Email))
            validationErrors.Add("Email address is required.");
        else if (!IsValidEmail(formData.Email))
            validationErrors.Add("Email address format is invalid.");

        if (!string.IsNullOrWhiteSpace(formData.Phone) && !IsValidPhone(formData.Phone))
            validationErrors.Add("Phone number format is invalid.");

        if (!formData.AcceptTerms)
            validationErrors.Add("You must accept the terms and conditions.");
    }

    private bool IsValidEmail(string email)
    {
        try
        {
            var addr = new System.Net.Mail.MailAddress(email);
            return addr.Address == email;
        }
        catch
        {
            return false;
        }
    }

    private bool IsValidPhone(string phone)
    {
        // Remove common separators
        string cleaned = Regex.Replace(phone, @"[\s\-\(\)\.]", "");
        return Regex.IsMatch(cleaned, @"^\d{10,}$");
    }

    private async Task HandleSubmit()
    {
        try
        {
            ValidateForm();

            if (validationErrors.Any())
                return;

            isProcessing = true;

            // Simulate processing delay
            await System.Threading.Tasks.Task.Delay(500);

            isSubmitted = true;
            errorMessage = null;
        }
        catch (Exception ex)
        {
            errorMessage = $"Error processing registration: {ex.Message}";
        }
        finally
        {
            isProcessing = false;
        }
    }

    private void GoBack()
    {
        try
        {
            Navigation.NavigateTo($"/event/{EventId}");
        }
        catch (Exception ex)
        {
            errorMessage = $"Error navigating back: {ex.Message}";
        }
    }

    private void ReturnToEvents()
    {
        try
        {
            Navigation.NavigateTo("/events");
        }
        catch (Exception ex)
        {
            errorMessage = $"Error navigating to events: {ex.Message}";
        }
    }

    private string FormatDateTime(DateTime date)
    {
        try
        {
            return date.ToString("dddd, MMMM dd, yyyy h:mm tt");
        }
        catch
        {
            return "Date not available";
        }
    }
}
