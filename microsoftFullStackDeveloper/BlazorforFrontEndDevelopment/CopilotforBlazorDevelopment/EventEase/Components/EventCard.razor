@using EventEase.Models

@if (IsValidEvent)
{
    <div class="event-card @(IsRegistered ? "registered" : "")">
        @if (IsRegistered)
        {
            <div class="registered-badge">✓ Registered</div>
        }
        
        <div class="card-header">
            <h3>@Event.EventName</h3>
            <span class="category-badge">@Event.Category</span>
        </div>
        
        <div class="card-body">
            <p class="event-description">@Event.Description</p>
            
            <div class="event-details">
                <div class="detail-item">
                    <span class="detail-label">📅 Date:</span>
                    <span class="detail-value">@FormatEventDate(Event.EventDate)</span>
                </div>
                
                <div class="detail-item">
                    <span class="detail-label">📍 Location:</span>
                    <span class="detail-value">@Event.Location</span>
                </div>
                
                <div class="detail-item">
                    <span class="detail-label">👥 Attendees:</span>
                    <span class="detail-value">@Event.RegisteredAttendees / @Event.MaxAttendees</span>
                </div>
            </div>
            
            <div class="card-actions">
                @if (Event.IsAvailable)
                {
                    <button class="btn btn-primary" @onclick="@(() => OnEventSelected.InvokeAsync(Event.Id))">
                        View Details
                    </button>
                    <button class="btn btn-success" @onclick="@(() => OnRegisterClick.InvokeAsync(Event.Id))" disabled="@IsRegistered">
                        @(IsRegistered ? "Already Registered" : "Register")
                    </button>
                }
                else
                {
                    <button class="btn btn-disabled" disabled>Event Full</button>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public Event Event { get; set; } = new();

    [Parameter]
    public bool IsRegistered { get; set; }

    [Parameter]
    public EventCallback<int> OnEventSelected { get; set; }

    [Parameter]
    public EventCallback<int> OnRegisterClick { get; set; }

    private bool IsValidEvent => Event != null && Event.IsValid();

    private string FormatEventDate(DateTime date)
    {
        try
        {
            return date.ToString("dddd, MMMM dd, yyyy");
        }
        catch
        {
            return "Date not available";
        }
    }
}
