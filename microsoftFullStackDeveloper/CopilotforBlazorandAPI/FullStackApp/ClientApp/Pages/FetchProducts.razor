@page "/fetchproducts"
@using System.Net.Http
@using System.Text.Json
@using System.Text.Json.Serialization
@inject HttpClient Http

<h3>Product List</h3>

@if (errorMessage != null)
{
    <div class="alert alert-danger">@errorMessage</div>
}

<ul>
    @if (products != null)
    {
        foreach (var product in products)
        {
            <li>@product.Name - $@product.Price (Stock: @product.Stock)</li>
        }
    }
    else if (errorMessage == null)
    {
        <li>Loading...</li>
    }
</ul>

@code {
    private Product[]? products;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = await Http.GetAsync("http://localhost:5252/api/productlist");
            response.EnsureSuccessStatusCode();
            var json = await response.Content.ReadAsStringAsync();
            
            var options = new JsonSerializerOptions 
            { 
                PropertyNameCaseInsensitive = true 
            };
            products = JsonSerializer.Deserialize<Product[]>(json, options);
        }
        catch (HttpRequestException ex)
        {
            errorMessage = $"Error fetching products: {ex.Message}";
            Console.WriteLine($"HttpRequestException: {ex.Message}");
        }
        catch (JsonException ex)
        {
            errorMessage = $"Error deserializing JSON: {ex.Message}";
            Console.WriteLine($"JsonException: {ex.Message}");
        }
        catch (TaskCanceledException)
        {
            errorMessage = "Request timed out. Please try again.";
        }
        catch (Exception ex)
        {
            errorMessage = $"An unexpected error occurred: {ex.Message}";
            Console.WriteLine($"Exception: {ex.Message}");
        }
    }

    public class Product
    {
        [JsonPropertyName("id")]
        public int Id { get; set; }
        
        [JsonPropertyName("name")]
        public string Name { get; set; } = string.Empty;
        
        [JsonPropertyName("price")]
        public double Price { get; set; }
        
        [JsonPropertyName("stock")]
        public int Stock { get; set; }
    }
}